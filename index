// =============================================
// DRAG & DROP
// =============================================
function setupDragDrop() {
  const zone = document.getElementById('upload-zone');
  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
  zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('dragover');
    handleFiles(e.dataTransfer.files);
  });
}

// =============================================
// FILE HANDLING
// =============================================
function handleFiles(fileList) {
  if (!fileList || fileList.length === 0) return;
  const allowed = ['image/jpeg', 'image/jpg', 'image/png', 'image/jfif'];
  const allowedExt = ['.jpg', '.jpeg', '.png', '.jfif'];
  const allFiles = Array.from(fileList);
  const newFiles = allFiles.filter(f => {
    const ext = '.' + f.name.split('.').pop().toLowerCase();
    return allowed.includes(f.type.toLowerCase()) || allowedExt.includes(ext);
  });
  const rejected = allFiles.length - newFiles.length;
  if (rejected > 0) showAlert(`⚠️ ${rejected} file ditolak (hanya JPG, PNG, JFIF yang diterima)`, 'error');
  if (newFiles.length === 0) return;

  files = [...files, ...newFiles];
  updateStats();
  renderImageGrid();

  document.getElementById('process-controls').style.display = 'flex';
}

function renderImageGrid() {
  const grid = document.getElementById('image-grid');
  // Revoke existing blob URLs before clearing to prevent memory leaks
  grid.querySelectorAll('img').forEach(img => {
    if (img.src && img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
  });
  grid.classList.remove('hidden');
  grid.innerHTML = '';
  files.forEach((file, idx) => {
    const url = URL.createObjectURL(file);
    const card = document.createElement('div');
    card.className = 'image-card';
    card.id = `img-card-${idx}`;

    const img = document.createElement('img');
    img.src = url;
    img.alt = file.name;
    img.style.cssText = 'width:100%;aspect-ratio:1;object-fit:cover;display:block;';

    const info = document.createElement('div');
    info.className = 'image-card-info';

    const nameDiv = document.createElement('div');
    nameDiv.className = 'image-card-name';
    nameDiv.title = file.name;
    nameDiv.textContent = file.name;

    const statusDiv = document.createElement('div');
    statusDiv.className = 'image-card-status status-pending';
    statusDiv.id = `img-status-${idx}`;
    statusDiv.textContent = '⏳ Menunggu';

    info.appendChild(nameDiv);
    info.appendChild(statusDiv);
    card.appendChild(img);
    card.appendChild(info);
    grid.appendChild(card);
  });
}

function updateStats() {
  document.getElementById('stat-total').textContent = files.length;
  const done = processedImages.length;
  document.getElementById('stat-done').textContent = done;
  document.getElementById('stat-pending').textContent = Math.max(0, files.length - done);
}

function clearAll() {
  if (isProcessing) return;
  // Revoke all preview blob URLs before clearing
  const grid = document.getElementById('image-grid');
  grid.querySelectorAll('img').forEach(img => {
    if (img.src && img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
  });
  files = [];
  processedImages = [];
  document.getElementById('image-grid').innerHTML = '';
  document.getElementById('image-grid').classList.add('hidden');
  document.getElementById('process-controls').style.display = 'none';
  document.getElementById('progress-section').classList.add('hidden');
  document.getElementById('file-input').value = '';
  document.getElementById('stat-error').textContent = '0';
  document.getElementById('output-empty').classList.remove('hidden');
  document.getElementById('output-ready').classList.add('hidden');
  document.getElementById('progress-fill').style.width = '0%';
  document.getElementById('progress-pct').textContent = '0%';
  clearLog();
  updateStats();
}

// =============================================
// WAKE LOCK — Prevent tab throttling
// =============================================
let wakeLock = null;

async function requestWakeLock() {
  try {
    if ('wakeLock' in navigator) {
      wakeLock = await navigator.wakeLock.request('screen');
      addLog('info', '🔒 Wake Lock aktif — tab tidak akan dibekukan');
      wakeLock.addEventListener('release', () => {
        addLog('warn', '🔓 Wake Lock dilepas oleh sistem');
      });
    }
  } catch(e) {
    addLog('warn', '⚠️ Wake Lock tidak didukung browser ini: ' + e.message);
  }
}

async function releaseWakeLock() {
  if (wakeLock) {
    try { await wakeLock.release(); } catch(e) {}
    wakeLock = null;
  }
}

// Re-acquire wake lock if page becomes visible again
document.addEventListener('visibilitychange', async () => {
  if (isProcessing && document.visibilityState === 'visible') {
    await requestWakeLock();
  }
});

// =============================================
// WEB WORKER — Heavy pixel processing
// =============================================
// Inline worker code as blob URL so no separate file needed
const WORKER_CODE = `
self.onmessage = function(e) {
  const { type, data, width, height } = e.data;

  if (type === 'sharpen') {
    // Unsharp mask kernel
    const kernel = [0, -0.5, 0, -0.5, 3, -0.5, 0, -0.5, 0];
    const src = data;
    const out = new Uint8ClampedArray(src.length);
    const w = width, h = height;

    for (let y = 1; y < h - 1; y++) {
      for (let x = 1; x < w - 1; x++) {
        for (let c = 0; c < 3; c++) {
          let val = 0;
          for (let ky = -1; ky <= 1; ky++) {
            for (let kx = -1; kx <= 1; kx++) {
              const idx = ((y + ky) * w + (x + kx)) * 4 + c;
              val += src[idx] * kernel[(ky+1)*3+(kx+1)];
            }
          }
          out[(y * w + x) * 4 + c] = Math.min(255, Math.max(0, val));
        }
        out[(y * w + x) * 4 + 3] = src[(y * w + x) * 4 + 3];
      }
    }
    // Copy edges
    for (let x = 0; x < w; x++) {
      for (let c = 0; c < 4; c++) {
        out[x * 4 + c] = src[x * 4 + c];
        out[((h-1)*w+x)*4+c] = src[((h-1)*w+x)*4+c];
      }
    }
    for (let y = 0; y < h; y++) {
      for (let c = 0; c < 4; c++) {
        out[(y*w)*4+c] = src[(y*w)*4+c];
        out[(y*w+(w-1))*4+c] = src[(y*w+(w-1))*4+c];
      }
    }
    self.postMessage({ type: 'sharpen_done', data: out }, [out.buffer]);
  }

  if (type === 'enhance') {
    const src = new Uint8ClampedArray(data);
    const brightness = 8;
    const contrast = 15;
    const saturation = 1.1;
    const contrastFactor = (259 * (contrast + 255)) / (255 * (259 - contrast));

    for (let i = 0; i < src.length; i += 4) {
      let r = Math.min(255, src[i]   + brightness);
      let g = Math.min(255, src[i+1] + brightness);
      let b = Math.min(255, src[i+2] + brightness);

      r = Math.min(255, Math.max(0, contrastFactor * (r - 128) + 128));
      g = Math.min(255, Math.max(0, contrastFactor * (g - 128) + 128));
      b = Math.min(255, Math.max(0, contrastFactor * (b - 128) + 128));

      const maxC = Math.max(r, g, b) / 255;
      const minC = Math.min(r, g, b) / 255;
      const l = (maxC + minC) / 2;
      let s = 0;
      if (maxC !== minC) {
        s = l > 0.5 ? (maxC - minC) / (2 - maxC - minC) : (maxC - minC) / (maxC + minC);
      }
      const newS = Math.min(1, s * saturation);
      if (newS !== s && s > 0) {
        const factor = newS / s;
        const avg = (r + g + b) / 3;
        r = Math.min(255, Math.max(0, avg + (r - avg) * factor));
        g = Math.min(255, Math.max(0, avg + (g - avg) * factor));
        b = Math.min(255, Math.max(0, avg + (b - avg) * factor));
      }

      src[i] = r; src[i+1] = g; src[i+2] = b;
    }
    self.postMessage({ type: 'enhance_done', data: src }, [src.buffer]);
  }
};
`;

let pixelWorker = null;

function createWorker() {
  const blob = new Blob([WORKER_CODE], { type: 'application/javascript' });
  const url = URL.createObjectURL(blob);
  const worker = new Worker(url);
  URL.revokeObjectURL(url);
  return worker;
}

function runWorkerTask(worker, type, imageData) {
  return new Promise((resolve, reject) => {
    const dataCopy = new Uint8ClampedArray(imageData.data);
    worker.onmessage = (e) => {
      if (e.data.type === type + '_done') resolve(e.data.data);
      else reject(new Error('Worker unexpected message: ' + e.data.type));
    };
    worker.onerror = (e) => reject(new Error('Worker error: ' + e.message));
    worker.postMessage(
      { type, data: dataCopy, width: imageData.width, height: imageData.height },
      [dataCopy.buffer]
    );
  });
}

// =============================================
// SOUND NOTIFICATION — Play beep when done
// =============================================
function playDoneSound() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const notes = [523.25, 659.25, 783.99]; // C5, E5, G5 — major chord
    notes.forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0, ctx.currentTime + i * 0.15);
      gain.gain.linearRampToValueAtTime(0.3, ctx.currentTime + i * 0.15 + 0.05);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.15 + 0.6);
      osc.start(ctx.currentTime + i * 0.15);
      osc.stop(ctx.currentTime + i * 0.15 + 0.6);
    });
  } catch(e) {
    // Audio not supported - silently ignore
  }
}

// =============================================
// PROCESSING PIPELINE
// =============================================
async function startProcessing() {
  // Validate
  if (files.length === 0) { showAlert('Upload gambar terlebih dahulu!', 'error'); return; }
  if (settings.apiKeys.filter(k => k.trim()).length === 0) { showAlert('Tambahkan minimal 1 API Key di Settings!', 'error'); return; }
  if (settings.models.filter(m => m.trim()).length === 0) { showAlert('Tambahkan minimal 1 Model di Settings!', 'error'); return; }

  isProcessing = true;
  stopRequested = false;
  processedImages = [];

  // Activate Wake Lock to prevent tab throttling
  await requestWakeLock();

  // Create Web Worker for heavy pixel processing
  try {
    pixelWorker = createWorker();
  } catch(e) {
    pixelWorker = null;
    addLog('warn', '⚠️ Web Worker tidak tersedia, fallback ke main thread');
  }

  document.getElementById('btn-start').disabled = true;
  document.getElementById('btn-clear').disabled = true;
  document.getElementById('btn-stop').classList.remove('hidden');
  document.getElementById('progress-section').classList.remove('hidden');
  document.getElementById('output-empty').classList.remove('hidden');
  document.getElementById('output-ready').classList.add('hidden');

  clearLog();
  addLog('info', `Mulai memproses ${files.length} gambar...`);
  addLog('info', `Upscale: ${settings.upscale}× | API Keys: ${settings.apiKeys.filter(k=>k.trim()).length} | Models: ${settings.models.filter(m=>m.trim()).length}`);

  // ─────────────────────────────────────────
  // FASE 1 — Proses Visual Semua Gambar
  // Resize → Upscale → Enhancement
  // ─────────────────────────────────────────
  addLog('info', `\n── FASE 1: Proses Visual (${files.length} gambar) ──`);

  const visualResults = []; // { idx, filename, blob } or null if failed
  let fase1Done = 0;
  let fase1Error = 0;

  for (let i = 0; i < files.length; i++) {
    if (stopRequested) { addLog('warn', 'Proses dihentikan oleh pengguna.'); break; }

    const file = files[i];
    addLog('info', `[${i+1}/${files.length}] ${file.name}`);
    setImageStatus(i, 'processing', '⚙️ Fase 1...');
    document.getElementById('current-filename').textContent = `Fase 1 — [${i+1}/${files.length}] ${file.name}`;
    resetSteps();

    try {
      // STEP 1 — Resize
      setStep('resize', 'active');
      addLog('info', `  Step 1: Resize (${settings.upscale}×)...`);
      const resizedBlob = await resizeImage(file, settings.upscale);
      setStep('resize', 'done');

      // STEP 2 — Upscale Quality
      setStep('upscale', 'active');
      addLog('info', `  Step 2: Upscale kualitas...`);
      const upscaledBlob = await upscaleQuality(resizedBlob);
      setStep('upscale', 'done');

      // STEP 3 — Enhancement
      setStep('enhance', 'active');
      addLog('info', `  Step 3: Enhancement...`);
      const enhancedBlob = await enhanceImage(upscaledBlob);
      setStep('enhance', 'done');

      const outputFilename = file.name.replace(/\.[^.]+$/, '.jpg');
      visualResults.push({ idx: i, filename: outputFilename, blob: enhancedBlob });
      setImageStatus(i, 'processing', '⏳ Menunggu metadata...');
      addLog('success', `  ✅ Fase 1 selesai`);
      fase1Done++;

    } catch(err) {
      visualResults.push(null);
      setImageStatus(i, 'error', '❌ Gagal');
      addLog('error', `  ❌ Error: ${err.message}`);
      fase1Error++;
    }

    // Update progress (fase 1 = 0–50%)
    const pct = Math.round(((i+1) / files.length) * 50);
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    document.getElementById('progress-text').textContent = `Fase 1: ${i+1}/${files.length} gambar`;
    document.getElementById('stat-done').textContent = fase1Done;
    document.getElementById('stat-error').textContent = fase1Error;
    document.getElementById('stat-pending').textContent = Math.max(0, files.length - (i+1));
  }

  // Terminate worker after fase 1 — no longer needed
  if (pixelWorker) { pixelWorker.terminate(); pixelWorker = null; }

  if (stopRequested) {
    isProcessing = false;
    await releaseWakeLock();
    document.getElementById('btn-start').disabled = false;
    document.getElementById('btn-clear').disabled = false;
    document.getElementById('btn-stop').classList.add('hidden');
    addLog('warn', 'Proses dihentikan setelah Fase 1.');
    return;
  }

  addLog('success', `\nFase 1 selesai: ${fase1Done} berhasil, ${fase1Error} gagal.`);

  // ─────────────────────────────────────────
  // FASE 2 — Generate Metadata Satu per Satu
  // Semua model dipanggil bersamaan (race)
  // ─────────────────────────────────────────
  const validVisual = visualResults.filter(r => r !== null);
  if (validVisual.length === 0) {
    addLog('error', 'Tidak ada gambar yang lolos Fase 1. Proses dihentikan.');
    isProcessing = false;
    await releaseWakeLock();
    document.getElementById('btn-start').disabled = false;
    document.getElementById('btn-clear').disabled = false;
    document.getElementById('btn-stop').classList.add('hidden');
    showAlert('⚠️ Semua gambar gagal di Fase 1.', 'error');
    playDoneSound();
    return;
  }

  addLog('info', `\n── FASE 2: Generate Metadata (${validVisual.length} gambar) ──`);

  let fase2Done = 0;
  let fase2Error = 0;

  for (let i = 0; i < validVisual.length; i++) {
    if (stopRequested) { addLog('warn', 'Proses dihentikan oleh pengguna.'); break; }

    const item = validVisual[i];
    addLog('info', `[${i+1}/${validVisual.length}] Metadata: ${item.filename}`);
    document.getElementById('current-filename').textContent = `Fase 2 — [${i+1}/${validVisual.length}] ${item.filename}`;

    // Reset steps, activate only meta step
    resetSteps();
    setStep('meta', 'active');

    try {
      addLog('info', `  Memanggil semua model bersamaan (race)...`);
      const metadata = await generateMetadata(item.blob, item.filename);
      setStep('meta', 'done');
      addLog('success', `  ✅ Title: "${metadata.title.substring(0,50)}..."`);
      addLog('success', `  Category: ${metadata.category} (${CATEGORY_MAP[metadata.category] || ''})`);

      processedImages.push({
        filename: item.filename,
        blob: item.blob,
        metadata: metadata
      });

      setImageStatus(item.idx, 'done', '✅ Selesai');
      fase2Done++;

    } catch(err) {
      setStep('meta', 'error');
      setImageStatus(item.idx, 'error', '❌ Meta gagal');
      addLog('error', `  ❌ Metadata gagal: ${err.message}`);
      fase2Error++;
    }

    // Update progress (fase 2 = 50–100%)
    const pct = 50 + Math.round(((i+1) / validVisual.length) * 50);
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    document.getElementById('progress-text').textContent = `Fase 2: ${i+1}/${validVisual.length} metadata`;
    document.getElementById('stat-done').textContent = fase2Done;
    document.getElementById('stat-error').textContent = fase1Error + fase2Error;
  }

  // ─────────────────────────────────────────
  // SELESAI
  // ─────────────────────────────────────────
  isProcessing = false;
  await releaseWakeLock();

  document.getElementById('btn-start').disabled = false;
  document.getElementById('btn-clear').disabled = false;
  document.getElementById('btn-stop').classList.add('hidden');

  const totalDone = fase2Done;
  const totalError = fase1Error + fase2Error;
  addLog('success', `\n✅ Semua selesai! ${totalDone} berhasil, ${totalError} gagal.`);

  if (processedImages.length > 0) {
    playDoneSound();
    showOutputTab();
    showAlert(`✅ Selesai! ${totalDone} gambar siap didownload`, 'success');
    const outputTabBtn = document.querySelectorAll('.tab')[2];
    if (outputTabBtn) switchTab('output', outputTabBtn);
  } else {
    playDoneSound();
    showAlert('⚠️ Semua gambar gagal diproses. Cek log untuk detail.', 'error');
  }
}

function stopProcessing() {
  stopRequested = true;
  addLog('warn', 'Menghentikan proses...');
  releaseWakeLock();
}

// =============================================
// STEP 1: RESIZE (scale up pixels, keep ratio)
// =============================================
async function resizeImage(file, scale) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(file);
    img.onload = () => {
      try {
        const newW = Math.round(img.naturalWidth * scale);
        const newH = Math.round(img.naturalHeight * scale);
        const canvas = document.createElement('canvas');
        canvas.width = newW;
        canvas.height = newH;
        const ctx = canvas.getContext('2d');
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(img, 0, 0, newW, newH);
        canvas.toBlob(b => {
          URL.revokeObjectURL(url);
          if (b) resolve(b);
          else reject(new Error('Resize failed: toBlob returned null'));
        }, 'image/jpeg', 0.95);
      } catch(e) { URL.revokeObjectURL(url); reject(e); }
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Failed to load image for resize')); };
    img.src = url;
  });
}

// =============================================
// STEP 2: UPSCALE QUALITY (Sharpen + Detail)
// Uses Web Worker when available for non-blocking pixel processing
// =============================================
async function upscaleQuality(blob) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(blob);
    img.onload = () => {
      setTimeout(async () => {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0);
          URL.revokeObjectURL(url);

          const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);

          let outputData;
          if (pixelWorker) {
            // Off-load heavy sharpen to Web Worker
            outputData = await runWorkerTask(pixelWorker, 'sharpen', imageData);
          } else {
            // Fallback: run in main thread
            const data = imageData.data;
            const w = canvas.width, h = canvas.height;
            const kernel = [0, -0.5, 0, -0.5, 3, -0.5, 0, -0.5, 0];
            outputData = new Uint8ClampedArray(data.length);
            for (let y = 1; y < h - 1; y++) {
              for (let x = 1; x < w - 1; x++) {
                for (let c = 0; c < 3; c++) {
                  let val = 0;
                  for (let ky = -1; ky <= 1; ky++)
                    for (let kx = -1; kx <= 1; kx++)
                      val += data[((y+ky)*w+(x+kx))*4+c] * kernel[(ky+1)*3+(kx+1)];
                  outputData[(y*w+x)*4+c] = Math.min(255, Math.max(0, val));
                }
                outputData[(y*w+x)*4+3] = data[(y*w+x)*4+3];
              }
            }
            for (let x = 0; x < w; x++)
              for (let c = 0; c < 4; c++) {
                outputData[x*4+c] = data[x*4+c];
                outputData[((h-1)*w+x)*4+c] = data[((h-1)*w+x)*4+c];
              }
            for (let y = 0; y < h; y++)
              for (let c = 0; c < 4; c++) {
                outputData[(y*w)*4+c] = data[(y*w)*4+c];
                outputData[(y*w+(w-1))*4+c] = data[(y*w+(w-1))*4+c];
              }
          }

          const outImageData = new ImageData(outputData, canvas.width, canvas.height);
          ctx.putImageData(outImageData, 0, 0);
          canvas.toBlob(b => {
            if (b) resolve(b);
            else reject(new Error('Upscale quality failed'));
          }, 'image/jpeg', 0.95);
        } catch(e) { URL.revokeObjectURL(url); reject(e); }
      }, 10);
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Failed to load image for upscale')); };
    img.src = url;
  });
}

// =============================================
// STEP 3: IMAGE ENHANCEMENT (Adobe Stock Standard)
// Uses Web Worker when available for non-blocking pixel processing
// =============================================
async function enhanceImage(blob) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(blob);
    img.onload = async () => {
      try {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0);
        URL.revokeObjectURL(url);

        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);

        let outputData;
        if (pixelWorker) {
          // Off-load heavy enhancement to Web Worker
          outputData = await runWorkerTask(pixelWorker, 'enhance', imageData);
        } else {
          // Fallback: run in main thread
          const data = imageData.data;
          outputData = new Uint8ClampedArray(data);
          const brightness = 8, contrast = 15, saturation = 1.1;
          const contrastFactor = (259 * (contrast + 255)) / (255 * (259 - contrast));
          for (let i = 0; i < outputData.length; i += 4) {
            let r = Math.min(255, outputData[i]   + brightness);
            let g = Math.min(255, outputData[i+1] + brightness);
            let b = Math.min(255, outputData[i+2] + brightness);
            r = Math.min(255, Math.max(0, contrastFactor * (r - 128) + 128));
            g = Math.min(255, Math.max(0, contrastFactor * (g - 128) + 128));
            b = Math.min(255, Math.max(0, contrastFactor * (b - 128) + 128));
            const maxC = Math.max(r,g,b)/255, minC = Math.min(r,g,b)/255;
            const l = (maxC+minC)/2;
            let s = maxC !== minC ? (l > 0.5 ? (maxC-minC)/(2-maxC-minC) : (maxC-minC)/(maxC+minC)) : 0;
            const newS = Math.min(1, s * saturation);
            if (newS !== s && s > 0) {
              const factor = newS/s, avg = (r+g+b)/3;
              r = Math.min(255, Math.max(0, avg+(r-avg)*factor));
              g = Math.min(255, Math.max(0, avg+(g-avg)*factor));
              b = Math.min(255, Math.max(0, avg+(b-avg)*factor));
            }
            outputData[i]=r; outputData[i+1]=g; outputData[i+2]=b;
          }
        }

        const outImageData = new ImageData(outputData, canvas.width, canvas.height);
        ctx.putImageData(outImageData, 0, 0);
        canvas.toBlob(b => {
          if (b) resolve(b);
          else reject(new Error('Enhancement failed: toBlob returned null'));
        }, 'image/jpeg', 0.95);
      } catch(e) { URL.revokeObjectURL(url); reject(e); }
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Failed to load image for enhancement')); };
    img.src = url;
  });
}

// =============================================
// STEP 4: METADATA GENERATOR
// Race: semua model dipanggil bersamaan per API key
// Model tercepat yang menang, sisanya di-cancel
// =============================================
async function generateMetadata(blob, filename) {
  const base64 = await blobToBase64Compressed(blob, 1024);

  const prompt = `You are an Adobe Stock metadata expert. Analyze this image carefully and generate metadata.

Respond ONLY with a valid JSON object, no markdown, no explanation, exactly this format:
{
  "title": "Short descriptive title of the image (max 200 characters, in English)",
  "keywords": "keyword1, keyword2, keyword3, ... (max 49 keywords, comma-separated, ordered by relevance, in English)",
  "category": 11
}

Category must be a NUMBER from this list:
1=Animals, 2=Buildings and Architecture, 3=Business, 4=Drinks, 5=The Environment, 6=States of Mind, 7=Food, 8=Graphic Resources, 9=Hobbies and Leisure, 10=Industry, 11=Landscapes, 12=Lifestyle, 13=People, 14=Plants and Flowers, 15=Culture and Religion, 16=Science, 17=Social Issues, 18=Sports, 19=Technology, 20=Transport, 21=Travel

Rules:
- Title: descriptive, professional, max 200 chars
- Keywords: max 49, most relevant first, all lowercase, no duplicates
- Category: single number that best matches the image
- Output ONLY the JSON, nothing else`;

  const validKeys = settings.apiKeys.filter(k => k.trim());
  const validModels = settings.models.filter(m => m.trim());

  let lastError = null;

  // Try each API key one by one
  for (const apiKey of validKeys) {
    if (stopRequested) throw new Error('Dihentikan oleh pengguna');

    // Race: panggil semua model bersamaan, tercepat yang menang
    const controllers = validModels.map(() => new AbortController());

    const modelRaces = validModels.map((model, idx) =>
      callOpenRouter(apiKey.trim(), model.trim(), prompt, base64, controllers[idx].signal)
        .then(result => ({ result, model }))
    );

    addLog('info', `  Race ${validModels.length} model bersamaan (Key #${validKeys.indexOf(apiKey)+1})...`);

    try {
      // Promise.any — ambil yang pertama berhasil, abaikan yang gagal
      const winner = await Promise.any(modelRaces);

      // Cancel semua model lain yang masih berjalan
      controllers.forEach((ctrl, idx) => {
        if (validModels[idx] !== winner.model) {
          try { ctrl.abort(); } catch(e) {}
        }
      });

      addLog('success', `  ✓ Menang: ${winner.model.split('/').pop()}`);
      return winner.result;

    } catch(err) {
      // Promise.any throws AggregateError if ALL models fail
      // Extract last error message
      if (err.errors && err.errors.length > 0) {
        lastError = err.errors[err.errors.length - 1];
        addLog('warn', `  ✗ Semua model gagal di Key #${validKeys.indexOf(apiKey)+1}: ${lastError.message}`);
      } else {
        lastError = err;
        addLog('warn', `  ✗ Key #${validKeys.indexOf(apiKey)+1} gagal: ${err.message}`);
      }
      // Cancel all controllers for this key before trying next key
      controllers.forEach(ctrl => { try { ctrl.abort(); } catch(e) {} });
      await sleep(300);
    }
  }

  throw new Error(`Semua API key & model gagal. Error terakhir: ${lastError ? lastError.message : 'Tidak ada API key atau model yang valid'}`);
}

async function callOpenRouter(apiKey, model, prompt, base64, externalSignal) {
  // Use internal timeout controller combined with external race signal
  const timeoutController = new AbortController();
  const timeoutId = setTimeout(() => timeoutController.abort(), 30000);

  // Combine external signal (race cancel) + internal timeout
  const signal = externalSignal
    ? anySignal([externalSignal, timeoutController.signal])
    : timeoutController.signal;

  try {
    const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
        'HTTP-Referer': window.location.href,
        'X-Title': 'StockForge'
      },
      body: JSON.stringify({
        model: model,
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: [
            { type: 'image_url', image_url: { url: `data:image/jpeg;base64,${base64}` } },
            { type: 'text', text: prompt }
          ]
        }]
      }),
      signal
    });

    clearTimeout(timeoutId);

    if (!response.ok) {
      const errData = await response.json().catch(() => ({}));
      const errMsg = errData?.error?.message || errData?.message || `HTTP ${response.status}`;
      throw new Error(errMsg);
    }

    const data = await response.json();
    const content = data?.choices?.[0]?.message?.content;
    if (!content) throw new Error('Empty response from API');

    return parseMetadata(content);

  } catch(err) {
    clearTimeout(timeoutId);
    if (err.name === 'AbortError') throw new Error('Timeout atau dibatalkan');
    throw err;
  }
}

// Helper: combine multiple AbortSignals — aborts when ANY signal fires
function anySignal(signals) {
  const controller = new AbortController();
  for (const signal of signals) {
    if (signal.aborted) { controller.abort(); break; }
    signal.addEventListener('abort', () => controller.abort(), { once: true });
  }
  return controller.signal;
}

function parseMetadata(raw) {
  // Clean up response - remove markdown code blocks if present
  let cleaned = raw.trim();
  cleaned = cleaned.replace(/^```json\s*/i, '').replace(/\s*```$/i, '');
  cleaned = cleaned.replace(/^```\s*/i, '').replace(/\s*```$/i, '');
  cleaned = cleaned.trim();

  // Find JSON object
  const jsonMatch = cleaned.match(/\{[\s\S]*\}/);
  if (!jsonMatch) throw new Error('No JSON found in response');

  let parsed;
  try {
    parsed = JSON.parse(jsonMatch[0]);
  } catch(e) {
    throw new Error('Invalid JSON in response');
  }

  // Validate and sanitize
  let title = String(parsed.title || '').trim();
  if (!title) throw new Error('Empty title in response');
  if (title.length > 200) title = title.substring(0, 197) + '...';

  let keywordsRaw = String(parsed.keywords || '').trim();
  let keywords = keywordsRaw.split(',')
    .map(k => k.trim().toLowerCase())
    .filter(k => k.length > 0 && k.length < 50)
    .slice(0, 49);
  if (keywords.length === 0) throw new Error('Empty keywords in response');
  const keywordsStr = keywords.join(', ');

  let category = parseInt(parsed.category);
  if (isNaN(category) || category < 1 || category > 21) category = 11; // default Landscapes

  return { title, keywords: keywordsStr, category, releases: '' };
}

// =============================================
// HELPERS
// =============================================
async function blobToBase64Compressed(blob, maxSize) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(blob);
    img.onload = () => {
      try {
        let w = img.naturalWidth;
        let h = img.naturalHeight;
        if (w > maxSize || h > maxSize) {
          if (w > h) { h = Math.round(h * maxSize / w); w = maxSize; }
          else { w = Math.round(w * maxSize / h); h = maxSize; }
        }
        const canvas = document.createElement('canvas');
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, w, h);
        URL.revokeObjectURL(url);
        const base64 = canvas.toDataURL('image/jpeg', 0.85).split(',')[1];
        if (!base64) reject(new Error('Failed to convert image to base64'));
        else resolve(base64);
      } catch(e) { URL.revokeObjectURL(url); reject(e); }
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Failed to compress image for API')); };
    img.src = url;
  });
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function setImageStatus(idx, type, text) {
  const el = document.getElementById(`img-status-${idx}`);
  if (!el) return;
  el.className = `image-card-status status-${type}`;
  el.textContent = text;
}

function resetSteps() {
  ['resize','upscale','enhance','meta'].forEach(s => setStep(s, 'pending'));
}

function setStep(name, status) {
  const el = document.getElementById('step-' + name);
  if (!el) return;
  el.className = 'step-item ' + (status === 'active' ? 'active' : status === 'done' ? 'done' : status === 'error' ? 'error' : '');
  const icon = el.querySelector('.step-icon');
  if (icon) {
    icon.innerHTML = '';
    if (status === 'active') {
      const spin = document.createElement('span');
      spin.className = 'spinning';
      spin.textContent = '⟳';
      icon.appendChild(spin);
    } else if (status === 'done') {
      icon.textContent = '✅';
    } else if (status === 'error') {
      icon.textContent = '❌';
    } else {
      icon.textContent = '⬜';
    }
  }
}

function addLog(type, msg) {
  const container = document.getElementById('log-container');
  if (!container) return;
  const now = new Date();
  const time = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;
  const entry = document.createElement('div');
  entry.className = 'log-entry';
  const timeSpan = document.createElement('span');
  timeSpan.className = 'log-time';
  timeSpan.textContent = time;
  const msgSpan = document.createElement('span');
  msgSpan.className = 'log-' + type;
  msgSpan.textContent = msg;
  entry.appendChild(timeSpan);
  entry.appendChild(msgSpan);
  container.appendChild(entry);
  container.scrollTop = container.scrollHeight;
}

function clearLog() {
  const container = document.getElementById('log-container');
  if (container) container.innerHTML = '';
}

// =============================================
// OUTPUT
// =============================================
function showOutputTab() {
  document.getElementById('output-empty').classList.add('hidden');
  document.getElementById('output-ready').classList.remove('hidden');
  renderResultsTable();
}

function renderResultsTable() {
  const tbody = document.getElementById('results-tbody');
  tbody.innerHTML = '';
  processedImages.forEach(item => {
    const tr = document.createElement('tr');
    const catName = CATEGORY_MAP[item.metadata.category] || item.metadata.category;
    const kwArr = item.metadata.keywords.split(',');
    const kwPreview = kwArr.slice(0,5).join(', ') + (kwArr.length > 5 ? '...' : '');

    const tdFile = document.createElement('td');
    tdFile.title = item.filename;
    tdFile.textContent = item.filename;

    const tdTitle = document.createElement('td');
    const titleShort = item.metadata.title.length > 60 ? item.metadata.title.substring(0,60) + '...' : item.metadata.title;
    tdTitle.title = item.metadata.title;
    tdTitle.textContent = titleShort;

    const tdKw = document.createElement('td');
    tdKw.title = item.metadata.keywords;
    tdKw.textContent = kwPreview;

    const tdCat = document.createElement('td');
    tdCat.textContent = `${item.metadata.category} — ${catName}`;

    const tdStatus = document.createElement('td');
    tdStatus.style.color = 'var(--success)';
    tdStatus.textContent = '✅ OK';

    tr.appendChild(tdFile);
    tr.appendChild(tdTitle);
    tr.appendChild(tdKw);
    tr.appendChild(tdCat);
    tr.appendChild(tdStatus);
    tbody.appendChild(tr);
  });
}

async function downloadZip() {
  if (processedImages.length === 0) return;
  showAlert('Membuat ZIP...', 'info');
  try {
    const zip = new JSZip();
    const folder = zip.folder('stockforge_processed');
    processedImages.forEach(item => {
      folder.file(item.filename, item.blob);
    });
    const zipBlob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
    downloadBlob(zipBlob, 'stockforge_processed.zip');
    showAlert('✅ ZIP berhasil didownload!', 'success');
  } catch(e) {
    showAlert('❌ Gagal membuat ZIP: ' + e.message, 'error');
  }
}

function downloadCsv() {
  if (processedImages.length === 0) return;

  // CSV escape helper: wrap in quotes and escape internal quotes
  const csvEscape = (val) => `"${String(val).replace(/"/g, '""')}"`;

  const header = 'Filename,Title,Keywords,Category,Releases';
  const dataRows = processedImages.map(item => {
    return [
      csvEscape(item.filename),
      csvEscape(item.metadata.title),
      csvEscape(item.metadata.keywords),
      item.metadata.category,
      ''
    ].join(',');
  });

  const csv = [header, ...dataRows].join('\r\n'); // CRLF per RFC 4180
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  downloadBlob(blob, 'adobe_stock_metadata.csv');
  showAlert('✅ CSV berhasil didownload!', 'success');
}

function downloadBlob(blob, filename) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

