<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StockForge — Adobe Stock AI Processor</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap');

  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --surface2: #1a1a24;
    --border: #2a2a3a;
    --accent: #ff6b35;
    --accent2: #ff9f1c;
    --text: #f0f0f5;
    --text2: #9090a8;
    --success: #2ecc71;
    --error: #e74c3c;
    --warning: #f39c12;
    --processing: #3498db;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HEADER */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .logo span { color: var(--accent); }

  /* TABS */
  .tabs {
    display: flex;
    gap: 4px;
    background: var(--bg);
    padding: 4px;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .tab {
    padding: 8px 20px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--text2);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab.active {
    background: var(--accent);
    color: white;
    font-weight: 500;
  }

  .tab:hover:not(.active) { color: var(--text); background: var(--surface2); }

  /* MAIN */
  .main { padding: 40px; max-width: 1200px; margin: 0 auto; }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* SECTION TITLE */
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* CARDS */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 24px;
  }

  /* SETTING INPUT */
  .setting-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }

  .setting-input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }

  .setting-input:focus { border-color: var(--accent); }
  .setting-input::placeholder { color: var(--text2); }

  .btn {
    padding: 10px 18px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-accent {
    background: var(--accent);
    color: white;
  }

  .btn-accent:hover { background: #ff8555; transform: translateY(-1px); }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text2);
  }

  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  .btn-danger {
    background: transparent;
    border: 1px solid var(--error);
    color: var(--error);
    padding: 8px 12px;
    font-size: 12px;
  }

  .btn-danger:hover { background: var(--error); color: white; }

  .btn-success {
    background: var(--success);
    color: white;
  }

  .btn-success:hover { background: #27ae60; }

  .btn-large {
    padding: 14px 32px;
    font-size: 15px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
  }

  .btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none !important;
  }

  /* UPSCALE OPTIONS */
  .upscale-options {
    display: flex;
    gap: 10px;
  }

  .upscale-btn {
    padding: 10px 24px;
    border-radius: 8px;
    border: 2px solid var(--border);
    background: transparent;
    color: var(--text2);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .upscale-btn.selected {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(255,107,53,0.1);
  }

  .upscale-btn:hover:not(.selected) { border-color: var(--text2); color: var(--text); }

  /* UPLOAD ZONE */
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 60px 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    background: var(--surface);
    position: relative;
  }

  .upload-zone:hover, .upload-zone.dragover {
    border-color: var(--accent);
    background: rgba(255,107,53,0.05);
  }

  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-icon {
    font-size: 48px;
    margin-bottom: 16px;
    display: block;
  }

  .upload-title {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .upload-sub { color: var(--text2); font-size: 13px; }

  /* IMAGE GRID */
  .image-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
    margin-top: 24px;
  }

  .image-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }

  .image-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .image-card-info {
    padding: 8px 10px;
  }

  .image-card-name {
    font-size: 11px;
    color: var(--text2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .image-card-status {
    font-size: 11px;
    margin-top: 4px;
    font-weight: 500;
  }

  .status-pending { color: var(--text2); }
  .status-processing { color: var(--processing); }
  .status-done { color: var(--success); }
  .status-error { color: var(--error); }

  /* PROGRESS */
  .progress-container { margin: 24px 0; }

  .progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text2);
    margin-bottom: 8px;
  }

  .progress-bar {
    height: 6px;
    background: var(--surface2);
    border-radius: 10px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 10px;
    transition: width 0.4s ease;
    width: 0%;
  }

  /* CURRENT PROCESSING */
  .current-processing {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 20px;
    margin: 16px 0;
  }

  .current-file {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--accent);
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .step-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--text2);
  }

  .step-item.active { color: var(--processing); }
  .step-item.done { color: var(--success); }
  .step-item.error { color: var(--error); }

  .step-icon { font-size: 14px; width: 20px; text-align: center; }

  /* LOG */
  .log-container {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    height: 200px;
    overflow-y: auto;
    font-size: 12px;
    color: var(--text2);
    margin-top: 16px;
  }

  .log-entry {
    padding: 3px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    display: flex;
    gap: 8px;
  }

  .log-time { color: var(--accent2); opacity: 0.6; white-space: nowrap; }
  .log-info { color: var(--text2); }
  .log-success { color: var(--success); }
  .log-error { color: var(--error); }
  .log-warn { color: var(--warning); }

  /* OUTPUT */
  .output-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 24px;
  }

  .output-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 30px;
    text-align: center;
  }

  .output-icon { font-size: 48px; margin-bottom: 16px; display: block; }

  .output-title {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .output-desc { color: var(--text2); font-size: 13px; margin-bottom: 20px; }

  /* STATS */
  .stats-bar {
    display: flex;
    gap: 20px;
    margin-bottom: 24px;
  }

  .stat-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 20px;
    flex: 1;
    text-align: center;
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-label { font-size: 11px; color: var(--text2); margin-top: 4px; }

  /* TAG */
  .tag {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
  }

  .tag-orange { background: rgba(255,107,53,0.15); color: var(--accent); border: 1px solid rgba(255,107,53,0.3); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text2); }

  /* DIVIDER */
  .divider { height: 1px; background: var(--border); margin: 20px 0; }

  /* FLEX UTILS */
  .flex { display: flex; }
  .flex-between { display: flex; justify-content: space-between; align-items: center; }
  .gap-10 { gap: 10px; }
  .mt-10 { margin-top: 10px; }
  .mt-20 { margin-top: 20px; }

  /* BADGE */
  .badge {
    background: var(--accent);
    color: white;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 20px;
    font-weight: 600;
  }

  /* ALERT */
  .alert {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 16px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .alert-warning { background: rgba(243,156,18,0.1); border: 1px solid rgba(243,156,18,0.3); color: var(--warning); }
  .alert-info { background: rgba(52,152,219,0.1); border: 1px solid rgba(52,152,219,0.3); color: var(--processing); }
  .alert-success { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: var(--success); }

  /* HIDDEN */
  .hidden { display: none !important; }

  /* ANIMATE */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .pulsing { animation: pulse 1.5s infinite; }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .spinning { animation: spin 1s linear infinite; display: inline-block; }

  /* METADATA PREVIEW */
  .meta-preview {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
    font-size: 12px;
    margin-top: 8px;
  }

  .meta-row { margin-bottom: 6px; display: flex; gap: 8px; }
  .meta-key { color: var(--accent2); min-width: 80px; }
  .meta-val { color: var(--text); word-break: break-all; }

  /* PROCESS CONTROLS */
  .process-controls {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 24px;
  }

  /* RESULTS TABLE */
  .results-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin-top: 16px;
  }

  .results-table th {
    background: var(--surface2);
    padding: 10px 12px;
    text-align: left;
    color: var(--text2);
    font-weight: 500;
    border-bottom: 1px solid var(--border);
  }

  .results-table td {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: top;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .results-table tr:hover td { background: var(--surface2); }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="logo">Stock<span>Forge</span></div>
  <div class="tabs">
    <button class="tab active" onclick="switchTab('settings', this)">⚙️ Settings</button>
    <button class="tab" onclick="switchTab('process', this)">🔄 Process</button>
    <button class="tab" onclick="switchTab('output', this)">💾 Output</button>
  </div>
  <div class="tag tag-orange">Adobe Stock Ready</div>
</div>

<div class="main">

  <!-- ===== TAB: SETTINGS ===== -->
  <div id="tab-settings" class="tab-content active">

    <!-- API KEYS -->
    <div class="section-title">🔑 OpenRouter API Keys</div>
    <div class="card">
      <div class="alert alert-info">
        ℹ️ API Keys tersimpan di browser kamu (localStorage). Tidak dikirim ke server manapun selain OpenRouter.
      </div>
      <div id="api-keys-list"></div>
      <button class="btn btn-outline mt-10" onclick="addApiKey()">+ Tambah API Key</button>
    </div>

    <!-- MODELS -->
    <div class="section-title">🤖 Models (Urutan = Prioritas Fallback)</div>
    <div class="card">
      <div class="alert alert-warning">
        ⚠️ Pastikan model yang digunakan mendukung Vision (melihat gambar). Jika model gagal, otomatis lanjut ke model berikutnya.
      </div>
      <div id="models-list"></div>
      <div class="flex gap-10 mt-10">
        <button class="btn btn-outline" onclick="addModel()">+ Tambah Model</button>
        <button class="btn btn-outline" onclick="addDefaultModels()">↺ Reset Default Models</button>
      </div>
    </div>

    <!-- UPSCALE -->
    <div class="section-title">📐 Upscale Size</div>
    <div class="card">
      <p style="font-size:13px; color:var(--text2); margin-bottom:16px;">Pilih berapa kali resolusi gambar akan diperbesar. Rasio gambar akan tetap dipertahankan.</p>
      <div class="upscale-options">
        <button class="upscale-btn" onclick="selectUpscale(2)" id="upscale-2">2×</button>
        <button class="upscale-btn selected" onclick="selectUpscale(4)" id="upscale-4">4×</button>
        <button class="upscale-btn" onclick="selectUpscale(8)" id="upscale-8">8×</button>
      </div>
      <p class="mt-10" style="font-size:12px; color:var(--text2);" id="upscale-info">Contoh: 1920×1080 → 3840×2160 (4×)</p>
    </div>

    <button class="btn btn-accent btn-large" onclick="saveSettings()">💾 Simpan Pengaturan</button>

  </div>

  <!-- ===== TAB: PROCESS ===== -->
  <div id="tab-process" class="tab-content">

    <!-- STATS -->
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-num" id="stat-total">0</div>
        <div class="stat-label">Total Gambar</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" id="stat-done" style="color:var(--success)">0</div>
        <div class="stat-label">Selesai</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" id="stat-error" style="color:var(--error)">0</div>
        <div class="stat-label">Gagal</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" id="stat-pending" style="color:var(--text2)">0</div>
        <div class="stat-label">Menunggu</div>
      </div>
    </div>

    <!-- UPLOAD -->
    <div class="section-title">📥 Upload Gambar</div>
    <div class="upload-zone" id="upload-zone">
      <input type="file" id="file-input" multiple accept=".jpg,.jpeg,.png,.jfif" onchange="handleFiles(this.files)">
      <span class="upload-icon">🖼️</span>
      <div class="upload-title">Drag & Drop Gambar AI Kamu</div>
      <div class="upload-sub">atau klik untuk memilih file • JPG, JPEG, PNG, JFIF • Bisa pilih banyak sekaligus</div>
    </div>

    <!-- IMAGE GRID -->
    <div id="image-grid" class="image-grid hidden"></div>

    <!-- PROCESS CONTROLS -->
    <div class="process-controls mt-20" id="process-controls" style="display:none;">
      <button class="btn btn-accent btn-large" id="btn-start" onclick="startProcessing()">🚀 Mulai Proses</button>
      <button class="btn btn-outline" id="btn-clear" onclick="clearAll()">🗑️ Hapus Semua</button>
      <button class="btn btn-danger hidden" id="btn-stop" onclick="stopProcessing()">⏹ Stop</button>
    </div>

    <!-- PROGRESS -->
    <div id="progress-section" class="hidden">
      <div class="progress-container">
        <div class="progress-label">
          <span id="progress-text">Memproses gambar...</span>
          <span id="progress-pct">0%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
      </div>

      <!-- CURRENT FILE STATUS -->
      <div class="current-processing" id="current-processing">
        <div class="current-file" id="current-filename">—</div>
        <div class="steps-list">
          <div class="step-item" id="step-resize">
            <span class="step-icon">⬜</span>
            <span>Step 1 — Perbesar Ukuran PX</span>
          </div>
          <div class="step-item" id="step-upscale">
            <span class="step-icon">⬜</span>
            <span>Step 2 — Upscale Kualitas</span>
          </div>
          <div class="step-item" id="step-enhance">
            <span class="step-icon">⬜</span>
            <span>Step 3 — Image Enhancement</span>
          </div>
          <div class="step-item" id="step-meta">
            <span class="step-icon">⬜</span>
            <span>Step 4 — Generate Metadata (AI Vision)</span>
          </div>
        </div>
      </div>

      <!-- LOG -->
      <div class="section-title" style="margin-top:20px;">📋 Log Proses</div>
      <div class="log-container" id="log-container"></div>
    </div>

  </div>

  <!-- ===== TAB: OUTPUT ===== -->
  <div id="tab-output" class="tab-content">

    <div id="output-empty" class="card" style="text-align:center; padding:60px;">
      <div style="font-size:48px; margin-bottom:16px;">📭</div>
      <div style="font-family:'Syne',sans-serif; font-size:18px; font-weight:700; margin-bottom:8px;">Belum Ada Output</div>
      <div style="color:var(--text2); font-size:13px;">Proses gambar terlebih dahulu di tab Process</div>
    </div>

    <div id="output-ready" class="hidden">

      <div class="alert alert-success">
        ✅ Semua gambar berhasil diproses! Silakan download hasil di bawah ini.
      </div>

      <div class="output-grid">
        <div class="output-card">
          <span class="output-icon">📦</span>
          <div class="output-title">Download ZIP</div>
          <div class="output-desc">Semua gambar hasil proses (resize + upscale + enhancement) dalam 1 file ZIP</div>
          <button class="btn btn-accent btn-large" id="btn-download-zip" onclick="downloadZip()">⬇️ Download ZIP</button>
        </div>
        <div class="output-card">
          <span class="output-icon">📄</span>
          <div class="output-title">Download CSV</div>
          <div class="output-desc">Metadata siap upload ke Adobe Stock (Filename, Title, Keywords, Category, Releases)</div>
          <button class="btn btn-success btn-large" id="btn-download-csv" onclick="downloadCsv()">⬇️ Download CSV</button>
        </div>
      </div>

      <!-- RESULTS TABLE -->
      <div class="section-title" style="margin-top:32px;">📊 Preview Metadata</div>
      <div class="card" style="overflow-x:auto;">
        <table class="results-table" id="results-table">
          <thead>
            <tr>
              <th>Filename</th>
              <th>Title</th>
              <th>Keywords</th>
              <th>Category</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="results-tbody"></tbody>
        </table>
      </div>

    </div>
  </div>

</div>

<!-- JSZip CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<script>
// =============================================
// STATE
// =============================================
const DEFAULT_MODELS = [
  'google/gemini-2.0-flash-exp:free',
  'meta-llama/llama-4-scout:free',
  'qwen/qwen2.5-vl-72b-instruct:free'
];

let settings = {
  apiKeys: [],
  models: [],
  upscale: 4
};

let files = [];
let processedImages = []; // {filename, blob, metadata}
let isProcessing = false;
let stopRequested = false;

const CATEGORY_MAP = {
  1: 'Animals',
  2: 'Buildings and Architecture',
  3: 'Business',
  4: 'Drinks',
  5: 'The Environment',
  6: 'States of Mind',
  7: 'Food',
