// =============================================
// INIT
// =============================================
function init() {
  loadSettings();
  renderApiKeys();
  renderModels();
  renderUpscale();
  setupDragDrop();
}

function loadSettings() {
  try {
    const saved = localStorage.getItem('stockforge_settings');
    if (saved) {
      const parsed = JSON.parse(saved);
      settings.apiKeys = Array.isArray(parsed.apiKeys) ? parsed.apiKeys : [];
      settings.models = Array.isArray(parsed.models) ? parsed.models : [];
      settings.upscale = [2,4,8].includes(parsed.upscale) ? parsed.upscale : 4;
    } else {
      settings.models = [
        'google/gemini-2.0-flash-exp:free',
        'meta-llama/llama-4-scout:free',
        'qwen/qwen2.5-vl-72b-instruct:free'
      ];
    }
  } catch(e) {
    console.error('Load settings error:', e);
    settings = { apiKeys: [], models: DEFAULT_MODELS, upscale: 4 };
  }
}

function saveSettings() {
  localStorage.setItem('stockforge_settings', JSON.stringify(settings));
  showAlert('✅ Pengaturan berhasil disimpan!', 'success');
}

function showAlert(msg, type = 'info') {
  const el = document.createElement('div');
  el.style.cssText = `
    position:fixed; top:80px; right:24px; z-index:9999;
    background:${type==='success'?'#2ecc71':type==='error'?'#e74c3c':'#3498db'};
    color:white; padding:12px 20px; border-radius:10px;
    font-family:'DM Mono',monospace; font-size:13px;
    box-shadow:0 4px 20px rgba(0,0,0,0.4);
    animation: slideIn 0.3s ease;
  `;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

// =============================================
// TABS
// =============================================
function switchTab(name, el) {
  document.querySelectorAll('.tab-content').forEach(e => e.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(e => e.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (el) el.classList.add('active');
}

// =============================================
// API KEYS
// =============================================
function renderApiKeys() {
  const container = document.getElementById('api-keys-list');
  container.innerHTML = '';
  if (settings.apiKeys.length === 0) {
    const p = document.createElement('p');
    p.style.cssText = 'font-size:13px;color:var(--text2);margin-bottom:12px;';
    p.textContent = 'Belum ada API key. Tambahkan minimal 1 API key OpenRouter kamu.';
    container.appendChild(p);
  }
  settings.apiKeys.forEach((key, idx) => {
    const row = document.createElement('div');
    row.className = 'setting-row';

    const label = document.createElement('span');
    label.style.cssText = 'font-size:12px;color:var(--text2);min-width:24px;';
    label.textContent = `#${idx+1}`;

    const input = document.createElement('input');
    input.className = 'setting-input';
    input.type = 'password';
    input.value = key;
    input.placeholder = 'sk-or-v1-...';
    input.addEventListener('input', () => { settings.apiKeys[idx] = input.value; });

    const delBtn = document.createElement('button');
    delBtn.className = 'btn btn-danger';
    delBtn.textContent = '✕';
    delBtn.addEventListener('click', () => removeApiKey(idx));

    row.appendChild(label);
    row.appendChild(input);
    row.appendChild(delBtn);
    container.appendChild(row);
  });
}

function addApiKey() {
  settings.apiKeys.push('');
  renderApiKeys();
}

function removeApiKey(idx) {
  settings.apiKeys.splice(idx, 1);
  renderApiKeys();
}

